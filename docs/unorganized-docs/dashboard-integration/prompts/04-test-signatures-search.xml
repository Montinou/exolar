<component_specification>
  <component name="SearchTests">
    <props>
      <prop name="onSelectTest" type="(signature: string) => void">Callback when test selected</prop>
    </props>
    <features>
      <feature>Debounced search input (300ms)</feature>
      <feature>Status filter dropdown</feature>
      <feature>Loading skeleton during search</feature>
      <feature>Result list with pass rate indicator</feature>
      <feature>Click to view test history</feature>
    </features>
  </component>

  <component name="TestHistoryModal">
    <props>
      <prop name="signature" type="string">Test signature to display</prop>
      <prop name="open" type="boolean">Modal visibility</prop>
      <prop name="onClose" type="() => void">Close callback</prop>
    </props>
    <features>
      <feature>Test name and file display</feature>
      <feature>Stats summary (total runs, pass rate, avg duration)</feature>
      <feature>History table with status, branch, date</feature>
      <feature>Link to full execution detail</feature>
    </features>
  </component>
</component_specification>

