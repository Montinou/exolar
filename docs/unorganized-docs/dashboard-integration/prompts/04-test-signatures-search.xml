      <param name="q" type="string" required="false">Search query (name or file)</param>
      <param name="status" type="string" required="false">Filter by status</param>
      <param name="limit" type="number" default="50">Max results</param>
      <param name="offset" type="number" default="0">Pagination offset</param>
    </parameters>
    <response>
{
  "results": [
    {
      "test_name": "should create case",
      "test_file": "tests/case/create.spec.ts",
